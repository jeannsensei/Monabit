# ============================================================
# MonaBit — Frontend Web .env (example for local development)
# Copy to .env and fill with real values
# ============================================================

# Supabase project URL. Same as backend SUPABASE_URL.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key. Same as backend SUPABASE_ANON_KEY.
# This is safe for client-side use (respects RLS policies).
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend API URL. Points to the Express server.
# Local dev: http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api
