# ============================================================
# MonaBit — Backend .env (example for local development)
# Copy to .env and fill with real values
# ============================================================

# ---------- REQUIRED ----------

# Supabase project URL. Find it in Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key. Safe for client-side use (respects RLS)
SUPABASE_ANON_KEY=eyJ...

# Supabase service_role key. SERVER ONLY — bypasses RLS for admin
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PostgreSQL connection string for Drizzle ORM (direct DB connection)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# ---------- OPTIONAL (shown with defaults) ----------

# CoinGecko API key (required since mid-2024). Get one free at coingecko.com
COINGECKO_API_KEY=CG-...

# CoinGecko API base URL
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Frontend origin for CORS. Local dev: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Rate limit window in ms (15 minutes by default)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per IP within the window
RATE_LIMIT_MAX=100

# Idempotency key TTL in seconds (24 hours by default)
IDEMPOTENCY_TTL_SECONDS=86400

# Log level
LOG_LEVEL=info

# Server port
PORT=8080

# Environment
NODE_ENV=development
